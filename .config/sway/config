### SwayFX eye candy ###############################################
# Window open/close animation (SwayFX 0.5.3+ / the "SwayFX (git)" session only;
# ignored with a harmless log warning on the packaged 0.5.2 fallback session).
animation_duration_ms 250

# Gaps between windows (needed for smart_corner_radius to round corners)
gaps inner 10
gaps outer 4

# Rounded corners (only when the window has gaps around it)
corner_radius 8
smart_corner_radius enable

# Drop shadows
shadows enable
shadows_on_csd enable
shadow_blur_radius 20
shadow_color #00000099

# Subtly dim inactive windows
default_dim_inactive 0.1

# Background blur (visible behind transparent surfaces / the bar)
blur enable
blur_passes 8
blur_radius 10
blur_xray disable

# macOS-style title bars
# state                 border      background  text      indicator   child_border
client.focused          #c0c0c0ff   #545454ff   #ffffff   #c0c0c0ff   #c0c0c0dd
client.focused_inactive #686868bb   #3a3a3aee   #d8d8d8   #686868bb   #00000000
client.unfocused        #585858aa   #303030ee   #c0c0c0   #585858aa   #00000000
client.urgent           #cc4444dd   #3a2020ff   #ff6b6b   #cc4444dd   #00000000
titlebar_padding 10 6

# Blur on the Waybar layer
layer_effects "waybar" blur enable;

# Frosted glass behind the rofi launcher
layer_effects "rofi" {
    blur enable;
    blur_ignore_transparent enable;
    corner_radius 14;
    shadows enable;
}

# Notifications (mako): no compositor layer effects.
# mako's layer surface is larger than the visible card, so blur/shadow/corner
# effects produce an oversized "glass" halo. mako draws its own rounded corners
# and border (see ~/.config/mako/config), so no layer_effects are needed here.
