# macOS-style dark gray notifications (mako)
# No compositor blur on this layer — mako draws its own corners and border.

# Layout / behavior
sort=-time
layer=overlay
anchor=top-right
max-visible=5
default-timeout=6000
ignore-timeout=0
font=JetBrainsMono Nerd Font 11
width=380
height=160
margin=12
outer-margin=12,12,0,0
padding=14
border-size=1
border-radius=12
icons=1
max-icon-size=48
icon-border-radius=8

# Neutral dark gray card — macOS feel
background-color=#363636f0
text-color=#f0f0f0
border-color=#787878
progress-color=over #4a4a4a88

[urgency=low]
border-color=#5a5a5a
text-color=#c0c0c0
default-timeout=4000

[urgency=normal]
border-color=#787878

[urgency=high]
border-color=#cc4444
text-color=#ffffff
default-timeout=0

[mode=dnd]
invisible=1
